{
  "manifest_version": 3,
  "name": "Amazon Scraper",
  "version": "1.3.6",
  "description": "Simple Listing & Reviews Scraper for Amazon",
  "author": "Aihang",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://*.amazon.de/*",
    "https://*.amazon.fr/*",
    "https://*.amazon.it/*",
    "https://*.amazon.es/*",
    "https://*.amazon.nl/*",
    "https://*.amazon.se/*",
    "https://*.amazon.pl/*",
    "https://*.amazon.com.be/*",
    "https://*.amazon.co.uk/*",
    "https://*.amazon.ie/*",
    "https://*.amazon.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Scrape this product"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
