# ── Residential proxy (key to reducing Amazon bot-blocking) ──
# Comma-separated list for rotation across retries, e.g.:
# AMAZON_PROXIES=http://user:pass@host1:port,http://user:pass@host2:port
# Or a single proxy:
# AMAZON_PROXY=http://user:pass@host:port
# Standard vars HTTPS_PROXY / HTTP_PROXY are also honored.
AMAZON_PROXIES=

# ── Fetch retries (each uses a fresh UA + proxy) ──
SCRAPE_MAX_RETRIES=4

# ── Server port ──
PORT=3000
